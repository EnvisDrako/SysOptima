        },
        {
            "label": "Build SysOptima Sensor (Release)",
            "type": "shell",
            "command": "MSBuild.exe SysOptima_Sensor/SysOptima_Sensor/SysOptima_Sensor.slnx /t:Build /p:Configuration=Release /p:Platform=x64",
            "problemMatcher": "$msCompile"
        }
    ]
}
